name = "vercel-ntfy-relay"
main = "src/index.js"
compatibility_date = "2024-01-01"

# Replace with your Cloudflare account ID (find via: wrangler whoami)
account_id = "YOUR_ACCOUNT_ID"

[vars]
# Replace with your secret ntfy topic name (generate with: openssl rand -hex 6)
NTFY_TOPIC = "vercel-deploy-CHANGE-ME"
